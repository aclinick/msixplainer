<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MsixExplorer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MsixExplorer"
    xmlns:models="using:MsixExplorer.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- â•â•â• Toolbar â•â•â• -->
        <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="8"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button AutomationProperties.AutomationId="BtnOpenPackage"
                        Command="{x:Bind ViewModel.OpenPackageCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                        <TextBlock Text="Open Package" />
                    </StackPanel>
                </Button>
                <Button AutomationProperties.AutomationId="BtnOpenSample"
                        Command="{x:Bind ViewModel.OpenSampleCommand}"
                        Style="{StaticResource SubtleButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                        <TextBlock Text="Open Sample" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="{x:Bind ViewModel.PackageFilePath, Mode=OneWay}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsPackageLoaded), Mode=OneWay}">
                <DropDownButton AutomationProperties.AutomationId="BtnExport"
                                Content="Export">
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem AutomationProperties.AutomationId="BtnExportMarkdown"
                                            Text="Export to Markdown"
                                            Command="{x:Bind ViewModel.ExportMarkdownCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8A5;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem AutomationProperties.AutomationId="BtnExportJson"
                                            Text="Export to JSON"
                                            Command="{x:Bind ViewModel.ExportJsonCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE943;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>

        <!-- â•â•â• Content area â•â•â• -->
        <Grid Grid.Row="1">

            <!-- Welcome state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind local:MainPage.InvertBoolToVisibility(ViewModel.IsPackageLoaded), Mode=OneWay}">
                <FontIcon Glyph="&#xED25;" FontSize="64"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="MSIXplainer"
                           HorizontalAlignment="Center"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Open an .msix or .appx package to analyze its manifest and review security findings."
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"
                           MaxWidth="400" />
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button AutomationProperties.AutomationId="BtnWelcomeOpen"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.OpenPackageCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                            <TextBlock Text="Open Package" />
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.AutomationId="BtnWelcomeSample"
                            Command="{x:Bind ViewModel.OpenSampleCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                            <TextBlock Text="Try Sample" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- â•â•â• Analysis view â•â•â• -->
            <NavigationView x:Name="NavView"
                            AutomationProperties.AutomationId="NavViewSections"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsPackageLoaded), Mode=OneWay}"
                            PaneDisplayMode="Left"
                            OpenPaneLength="260"
                            IsBackButtonVisible="Collapsed"
                            IsSettingsVisible="False"
                            SelectionChanged="NavView_SelectionChanged">

                <!-- Raw XML footer item -->
                <NavigationView.FooterMenuItems>
                    <NavigationViewItem AutomationProperties.AutomationId="NavRawXml"
                                        Content="Raw XML" Tag="raw-xml">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE943;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.FooterMenuItems>

                <!-- â•â•â• Content area: overview | section | raw xml â•â•â• -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Error bar -->
                    <InfoBar Grid.Row="0" Margin="16,8,16,0"
                             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                             Title="Error"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             Severity="Error"
                             CloseButtonCommand="{x:Bind ViewModel.DismissErrorCommand}" />

                    <!-- Main content + finding detail -->
                    <Grid Grid.Row="1" ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- â”€â”€ OVERVIEW â”€â”€ -->
                        <ScrollViewer Grid.Column="0"
                                      Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsOverviewSelected), Mode=OneWay}">
                            <StackPanel Spacing="16" Padding="24,16,24,24">
                                <!-- Summary cards -->
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Padding="16"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Package"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.DisplayName, Mode=OneWay}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="v" /><Run Text="{x:Bind ViewModel.PackageInfo.Version, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock Text="{x:Bind ViewModel.PackageInfo.Architecture, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="16"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Publisher"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.PublisherDisplayName, Mode=OneWay}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.MinOsVersion, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="16"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Findings"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.FindingsOverview, Mode=OneWay}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Assessment -->
                                <InfoBar IsOpen="True" IsClosable="False"
                                         Title="IT Review Summary"
                                         Message="{x:Bind ViewModel.AssessmentMessage, Mode=OneWay}"
                                         Severity="{x:Bind local:MainPage.SeverityToInfoBar(ViewModel.OverallSeverity), Mode=OneWay}" />

                                <!-- All findings -->
                                <TextBlock Text="All Findings" Style="{StaticResource SubtitleTextBlockStyle}" />

                                <ListView AutomationProperties.AutomationId="OverviewFindingsList"
                                          ItemsSource="{x:Bind ViewModel.CategoryFindings, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedFinding, Mode=TwoWay}"
                                          SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ManifestFinding">
                                            <Grid Padding="4,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0"
                                                          Glyph="{x:Bind SeverityIcon}"
                                                          FontSize="16"
                                                          Foreground="{x:Bind local:MainPage.SeverityToBrush(Severity)}"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind Title}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind CategoryLabel}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                <Border Grid.Column="3"
                                                        Padding="8,2"
                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                        Background="{x:Bind local:MainPage.SeverityToBackground(Severity)}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind SeverityLabel}"
                                                               Foreground="{x:Bind local:MainPage.SeverityToBrush(Severity)}"
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- â”€â”€ SECTION (property groups) â”€â”€ -->
                        <ScrollViewer Grid.Column="0"
                                      Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsSectionSelected), Mode=OneWay}">
                            <StackPanel Padding="24,16,24,24">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.CurrentGroups, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="24" />
                                    </ItemsRepeater.Layout>
                                    <DataTemplate x:DataType="models:ManifestPropertyGroup">
                                        <StackPanel Spacing="8">
                                            <!-- Group header -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="16"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind Header}"
                                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Margin="0,0,0,4" />

                                            <!-- Properties within group -->
                                            <ItemsRepeater ItemsSource="{x:Bind Properties}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="2" />
                                                </ItemsRepeater.Layout>
                                                <DataTemplate x:DataType="models:ManifestProperty">
                                                    <Border Padding="16,12"
                                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1">
                                                        <Grid ColumnSpacing="16">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{x:Bind Label}"
                                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                       VerticalAlignment="Top" />
                                                            <StackPanel Grid.Column="1" Spacing="4">
                                                                <TextBlock Text="{x:Bind Value}"
                                                                           TextWrapping="Wrap"
                                                                           IsTextSelectionEnabled="True" />
                                                                <TextBlock Text="{x:Bind Explanation}"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                            </StackPanel>
                                                            <!-- Finding badge (clickable) -->
                                                            <Button Grid.Column="2"
                                                                    AutomationProperties.AutomationId="BtnViewFinding"
                                                                    VerticalAlignment="Top"
                                                                    Padding="0" MinWidth="0" MinHeight="0"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Tag="{x:Bind Finding}"
                                                                    Click="ViewFinding_Click"
                                                                    Visibility="{x:Bind local:MainPage.BoolToVisibility(HasFinding)}">
                                                                <Border Padding="8,4"
                                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                                        Background="{x:Bind local:MainPage.SeverityToBackground(FindingSeverity)}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <FontIcon Glyph="{x:Bind FindingSeverityIcon}" FontSize="12"
                                                                                  Foreground="{x:Bind local:MainPage.SeverityToBrush(FindingSeverity)}" />
                                                                        <TextBlock Text="{x:Bind FindingSeverityLabel}"
                                                                                   Foreground="{x:Bind local:MainPage.SeverityToBrush(FindingSeverity)}"
                                                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- â”€â”€ RAW XML â”€â”€ -->
                        <ScrollViewer Grid.Column="0"
                                      Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsRawXmlSelected), Mode=OneWay}"
                                      Padding="24,16,24,24">
                            <TextBox AutomationProperties.AutomationId="RawXmlTextBox"
                                     Text="{x:Bind ViewModel.RawXml, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Cascadia Mono, Consolas, Courier New"
                                     FontSize="12" />
                        </ScrollViewer>

                        <!-- â”€â”€ FINDING DETAIL PANE (shared, right side) â”€â”€ -->
                        <Border Grid.Column="1" Width="380"
                                Visibility="{x:Bind local:MainPage.NullToCollapsed(ViewModel.SelectedFinding), Mode=OneWay}"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1,0,0,0">
                            <ScrollViewer Padding="20,16,20,24">
                                <StackPanel Spacing="16">
                                    <!-- Close button -->
                                    <Button AutomationProperties.AutomationId="BtnCloseFinding"
                                            HorizontalAlignment="Right"
                                            Command="{x:Bind ViewModel.DismissSelectedFindingCommand}"
                                            Padding="4" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>

                                    <!-- Header -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="{x:Bind ViewModel.SelectedFinding.SeverityIcon, Mode=OneWay}"
                                                      FontSize="24"
                                                      Foreground="{x:Bind local:MainPage.SeverityToBrush(ViewModel.SelectedFinding.Severity), Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Title, Mode=OneWay}"
                                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Padding="8,4"
                                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                                    Background="{x:Bind local:MainPage.SeverityToBackground(ViewModel.SelectedFinding.Severity), Mode=OneWay}">
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFinding.SeverityLabel, Mode=OneWay}"
                                                           Foreground="{x:Bind local:MainPage.SeverityToBrush(ViewModel.SelectedFinding.Severity), Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <Border Padding="8,4"
                                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFinding.CategoryLabel, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                    <!-- What this means -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="What this means"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Description, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Why IT should care -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Why IT should care"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.WhyItMatters, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Recommendation -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Recommendation"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Recommendation, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- XML snippet -->
                                    <StackPanel Spacing="8"
                                                Visibility="{x:Bind local:MainPage.StringToVisibility(ViewModel.SelectedFinding.XmlSnippet), Mode=OneWay}">
                                        <TextBlock Text="Manifest XML"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <Border Padding="16"
                                                CornerRadius="{StaticResource ControlCornerRadius}"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedFinding.XmlSnippet, Mode=OneWay}"
                                                       FontFamily="Cascadia Mono, Consolas, Courier New"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </NavigationView>
        </Grid>
    </Grid>
</Page>
