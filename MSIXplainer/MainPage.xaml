<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MSIXplainer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MSIXplainer"
    xmlns:models="using:MSIXplainer.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView x:Name="NavView"
                    AutomationProperties.AutomationId="NavViewMain"
                    PaneDisplayMode="Auto"
                    OpenPaneLength="280"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    AlwaysShowHeader="False"
                    SelectionChanged="NavView_SelectionChanged"
                    ItemInvoked="NavView_ItemInvoked"
                    Expanding="NavView_Expanding">

        <!-- ═══ Content area ═══ -->
        <Grid ColumnSpacing="0" Padding="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Apps secondary pane (Outlook-style; visible when Apps mode is on) ── -->
            <Border Grid.Column="0" Width="300"
                    Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsAppsPaneOpen), Mode=OneWay}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Pane header with close button -->
                    <Grid Grid.Row="0" Padding="16,12,8,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Installed Apps"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="MSIX / AppX packages on this PC"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                AutomationProperties.AutomationId="BtnCloseAppsPane"
                                Click="OnCloseAppsPaneClick"
                                Padding="6" MinWidth="0" MinHeight="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                        </Button>
                    </Grid>

                    <!-- Open from disk: primary action for picking a package that isn't installed -->
                    <Button Grid.Row="1"
                            AutomationProperties.AutomationId="BtnOpenPackageFromDisk"
                            Click="OnOpenPackageFromDiskClick"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="12,0,12,8"
                            Style="{StaticResource SubtleButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8E5;" FontSize="16" />
                            <TextBlock Text="Open .msix from disk…" />
                        </StackPanel>
                    </Button>

                    <!-- Loading state -->
                    <StackPanel Grid.Row="2"
                                Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsLoadingInstalledApps), Mode=OneWay}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <ProgressRing IsActive="True" Width="32" Height="32" />
                        <TextBlock Text="Loading installed apps…"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Apps list -->
                    <ListView Grid.Row="2"
                              AutomationProperties.AutomationId="LstInstalledApps"
                              ItemsSource="{x:Bind ViewModel.InstalledPackages}"
                              SelectionMode="Single"
                              ItemClick="OnInstalledAppClick"
                              IsItemClickEnabled="True"
                              Visibility="{x:Bind local:MainPage.InvertBoolToVisibility(ViewModel.IsLoadingInstalledApps), Mode=OneWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:InstalledPackage">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- App icon (bytes → BitmapImage); falls back to a generic glyph -->
                                    <Border Grid.Column="0" Width="32" Height="32"
                                            CornerRadius="4"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                                        <Grid>
                                            <FontIcon Glyph="&#xE7B8;" FontSize="16"
                                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                      Visibility="{x:Bind local:MainPage.NullObjectToVisibility(IconImage)}" />
                                            <Image Source="{x:Bind local:MainPage.ObjectToImageSource(IconImage)}"
                                                   Width="28" Height="28"
                                                   Stretch="Uniform"
                                                   Visibility="{x:Bind local:MainPage.NonNullObjectToVisibility(IconImage)}" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayName}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="v" /><Run Text="{x:Bind Version}" /><Run Text=" · " /><Run Text="{x:Bind Architecture}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- ── Sections secondary pane (Outlook-style; visible when a package is loaded
                 and the Apps pane isn't taking the column). Mirrors the Apps pane pattern. ── -->
            <Border Grid.Column="0" Width="280"
                    Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsSectionsPaneVisible), Mode=OneWay}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Pane header: package title -->
                    <StackPanel Grid.Row="0" Spacing="2" Padding="16,12,16,8">
                        <TextBlock Text="{x:Bind ViewModel.PackageInfo.DisplayName, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="v" /><Run Text="{x:Bind ViewModel.PackageInfo.Version, Mode=OneWay}" /><Run Text=" · " /><Run Text="{x:Bind ViewModel.PackageInfo.Architecture, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Sections list -->
                    <ListView Grid.Row="1"
                              AutomationProperties.AutomationId="LstSections"
                              ItemsSource="{x:Bind ViewModel.Sections}"
                              SelectedItem="{x:Bind ViewModel.SelectedSection, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ManifestSection">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" FontSize="16"
                                              VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Label}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <InfoBadge Grid.Column="2"
                                               Value="{x:Bind FindingCount}"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind local:MainPage.PositiveIntToVisibility(FindingCount)}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Pane footer: action buttons (Raw XML toggle + Export) -->
                    <StackPanel Grid.Row="2" Spacing="4" Padding="12,8,12,12"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0">
                        <Button AutomationProperties.AutomationId="BtnRawXml"
                                Click="OnRawXmlClick"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE943;" FontSize="16" />
                                <TextBlock Text="Raw XML" />
                            </StackPanel>
                        </Button>
                        <Button AutomationProperties.AutomationId="BtnExportMarkdown"
                                Command="{x:Bind ViewModel.ExportMarkdownCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                                <TextBlock Text="Export to Markdown" />
                            </StackPanel>
                        </Button>
                        <Button AutomationProperties.AutomationId="BtnExportJson"
                                Command="{x:Bind ViewModel.ExportJsonCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE74E;" FontSize="16" />
                                <TextBlock Text="Export to JSON" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Main content area (Compare frame or home content) ── -->
            <Grid Grid.Column="1">

            <!-- ── Compare Versions view (inner-frame; visible only in Compare mode) ── -->
            <Frame x:Name="CompareFrame"
                   Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsCompareMode), Mode=OneWay}" />

            <!-- ── Settings view (inner-frame; visible only in Settings mode) ── -->
            <Frame x:Name="SettingsFrame"
                   Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsSettingsMode), Mode=OneWay}" />

            <!-- ── Home content (welcome + analysis); hidden in Compare or Settings mode ── -->
            <Grid Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsHomeMode), Mode=OneWay}">

            <!-- Welcome state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                        Visibility="{x:Bind local:MainPage.InvertBoolToVisibility(ViewModel.IsPackageLoaded), Mode=OneWay}">
                <FontIcon Glyph="&#xED25;" FontSize="64"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="MSIXplainer"
                           HorizontalAlignment="Center"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="Open the Apps pane to pick an installed app or open an .msix from disk — or jump to Compare Versions to plan an update."
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"
                           MaxWidth="460" />
            </StackPanel>

            <!-- ═══ Analysis view ═══ -->
            <Grid Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsPackageLoaded), Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Error bar -->
                <InfoBar Grid.Row="0" Margin="16,8,16,0"
                         IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                         Title="Error"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         Severity="Error"
                         CloseButtonCommand="{x:Bind ViewModel.DismissErrorCommand}" />

                <!-- Main content + finding detail -->
                <Grid Grid.Row="1" ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- ── OVERVIEW ── -->
                    <ScrollViewer Grid.Column="0"
                                  Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsOverviewSelected), Mode=OneWay}">
                        <StackPanel Spacing="16" Padding="24,16,24,24">
                            <!-- Summary cards -->
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="16"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Package"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.PackageInfo.DisplayName, Mode=OneWay}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="v" /><Run Text="{x:Bind ViewModel.PackageInfo.Version, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.Architecture, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                    <Border Grid.Column="1" Padding="16"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Publisher"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.PublisherDisplayName, Mode=OneWay}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.MinOsVersion, Mode=OneWay}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="16"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Findings"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind ViewModel.PackageInfo.FindingsOverview, Mode=OneWay}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Assessment -->
                                <InfoBar IsOpen="True" IsClosable="False"
                                         Title="IT Review Summary"
                                         Message="{x:Bind ViewModel.AssessmentMessage, Mode=OneWay}"
                                         Severity="{x:Bind local:MainPage.SeverityToInfoBar(ViewModel.OverallSeverity), Mode=OneWay}" />

                                <!-- All findings -->
                                <TextBlock Text="All Findings" Style="{StaticResource SubtitleTextBlockStyle}" />

                                <ListView AutomationProperties.AutomationId="OverviewFindingsList"
                                          ItemsSource="{x:Bind ViewModel.CategoryFindings, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedFinding, Mode=TwoWay}"
                                          SelectionMode="Single">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ManifestFinding">
                                            <Grid Padding="4,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0"
                                                          Glyph="{x:Bind SeverityIcon}"
                                                          FontSize="16"
                                                          Foreground="{x:Bind local:MainPage.SeverityToBrush(Severity)}"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind Title}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Grid.Column="2" Text="{x:Bind CategoryLabel}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                <Border Grid.Column="3"
                                                        Padding="8,2"
                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                        Background="{x:Bind local:MainPage.SeverityToBackground(Severity)}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind SeverityLabel}"
                                                               Foreground="{x:Bind local:MainPage.SeverityToBrush(Severity)}"
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── SECTION (property groups) ── -->
                        <ScrollViewer Grid.Column="0"
                                      Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsSectionSelected), Mode=OneWay}">
                            <StackPanel Padding="24,16,24,24">
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.CurrentGroups, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="24" />
                                    </ItemsRepeater.Layout>
                                    <DataTemplate x:DataType="models:ManifestPropertyGroup">
                                        <StackPanel Spacing="8">
                                            <!-- Group header -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="16"
                                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{x:Bind Header}"
                                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Margin="0,0,0,4" />

                                            <!-- Properties within group -->
                                            <ItemsRepeater ItemsSource="{x:Bind Properties}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="2" />
                                                </ItemsRepeater.Layout>
                                                <DataTemplate x:DataType="models:ManifestProperty">
                                                    <Border Padding="16,12"
                                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1">
                                                        <Grid ColumnSpacing="16">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{x:Bind Label}"
                                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                                       VerticalAlignment="Top" />
                                                            <StackPanel Grid.Column="1" Spacing="4">
                                                                <TextBlock Text="{x:Bind Value}"
                                                                           TextWrapping="Wrap"
                                                                           IsTextSelectionEnabled="True" />
                                                                <TextBlock Text="{x:Bind Explanation}"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                                            </StackPanel>
                                                            <!-- Copy value to clipboard -->
                                                            <Button Grid.Column="2"
                                                                    AutomationProperties.AutomationId="BtnCopyProperty"
                                                                    AutomationProperties.Name="Copy value to clipboard"
                                                                    ToolTipService.ToolTip="Copy value to clipboard"
                                                                    VerticalAlignment="Top"
                                                                    Padding="6" MinWidth="0" MinHeight="0"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Tag="{x:Bind Value}"
                                                                    Click="CopyPropertyValue_Click">
                                                                <FontIcon Glyph="&#xE8C8;" FontSize="14"
                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                            </Button>
                                                            <!-- Finding badge (clickable) -->
                                                            <Button Grid.Column="3"
                                                                    AutomationProperties.AutomationId="BtnViewFinding"
                                                                    VerticalAlignment="Top"
                                                                    Padding="0" MinWidth="0" MinHeight="0"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Tag="{x:Bind Finding}"
                                                                    Click="ViewFinding_Click"
                                                                    Visibility="{x:Bind local:MainPage.BoolToVisibility(HasFinding)}">
                                                                <Border Padding="8,4"
                                                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                                                        Background="{x:Bind local:MainPage.SeverityToBackground(FindingSeverity)}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <FontIcon Glyph="{x:Bind FindingSeverityIcon}" FontSize="12"
                                                                                  Foreground="{x:Bind local:MainPage.SeverityToBrush(FindingSeverity)}" />
                                                                        <TextBlock Text="{x:Bind FindingSeverityLabel}"
                                                                                   Foreground="{x:Bind local:MainPage.SeverityToBrush(FindingSeverity)}"
                                                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ── RAW XML ── -->
                        <ScrollViewer Grid.Column="0"
                                      Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsRawXmlSelected), Mode=OneWay}"
                                      Padding="24,16,24,24">
                            <TextBox AutomationProperties.AutomationId="RawXmlTextBox"
                                     Text="{x:Bind ViewModel.RawXml, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Cascadia Mono, Consolas, Courier New"
                                     FontSize="12" />
                        </ScrollViewer>

                        <!-- ── FINDING DETAIL PANE (shared, right side) ── -->
                        <Border Grid.Column="1" Width="380"
                                Visibility="{x:Bind local:MainPage.NullToCollapsed(ViewModel.SelectedFinding), Mode=OneWay}"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1,0,0,0">
                            <ScrollViewer Padding="20,16,20,24">
                                <StackPanel Spacing="16">
                                    <!-- Close button -->
                                    <Button AutomationProperties.AutomationId="BtnCloseFinding"
                                            HorizontalAlignment="Right"
                                            Command="{x:Bind ViewModel.DismissSelectedFindingCommand}"
                                            Padding="4" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0">
                                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                                    </Button>

                                    <!-- Header -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <FontIcon Glyph="{x:Bind ViewModel.SelectedFinding.SeverityIcon, Mode=OneWay}"
                                                      FontSize="24"
                                                      Foreground="{x:Bind local:MainPage.SeverityToBrush(ViewModel.SelectedFinding.Severity), Mode=OneWay}" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Title, Mode=OneWay}"
                                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Padding="8,4"
                                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                                    Background="{x:Bind local:MainPage.SeverityToBackground(ViewModel.SelectedFinding.Severity), Mode=OneWay}">
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFinding.SeverityLabel, Mode=OneWay}"
                                                           Foreground="{x:Bind local:MainPage.SeverityToBrush(ViewModel.SelectedFinding.Severity), Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                            <Border Padding="8,4"
                                                    CornerRadius="{StaticResource ControlCornerRadius}"
                                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                                <TextBlock Text="{x:Bind ViewModel.SelectedFinding.CategoryLabel, Mode=OneWay}"
                                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                    <!-- What this means -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="What this means"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Description, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Why IT should care -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Why IT should care"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.WhyItMatters, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- Recommendation -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Recommendation"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedFinding.Recommendation, Mode=OneWay}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- XML snippet -->
                                    <StackPanel Spacing="8"
                                                Visibility="{x:Bind local:MainPage.StringToVisibility(ViewModel.SelectedFinding.XmlSnippet), Mode=OneWay}">
                                        <TextBlock Text="Manifest XML"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <Border Padding="16"
                                                CornerRadius="{StaticResource ControlCornerRadius}"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedFinding.XmlSnippet, Mode=OneWay}"
                                                       FontFamily="Cascadia Mono, Consolas, Courier New"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
            </Grid>
            </Grid>
    </NavigationView>
</Page>
