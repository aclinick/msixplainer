<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MSIXplainer.Pages.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MSIXplainer.ViewModels"
    xmlns:local="using:MSIXplainer.Pages"
    xmlns:models="using:MSIXplainer.Models"
    mc:Ignorable="d">

    <!-- ═══ Body: Bandwidth Planner sidebar (left) + scrollable content (right) ═══ -->
    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

            <!-- ── Bandwidth Planner sidebar: always visible (mirrors the Sections-pane
                 pattern from MainPage). Title + intro at top; Export action buttons
                 appear at the bottom once a comparison has results. ── -->
            <Border Grid.Column="0" Width="280"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Title / intro -->
                    <StackPanel Grid.Row="0" Spacing="8" Padding="16,16,16,12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8AB;" FontSize="20"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Compare Versions"
                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   TextWrapping="Wrap"
                                   Text="Pick two MSIX versions and analyze the delta: what's changed, how big the update download will be, and where you can deduplicate." />
                    </StackPanel>

                    <!-- ── Tool nav: Diff / Bandwidth Planner / Duplicates. Visible only
                         after a comparison has results so the user has something to view. ── -->
                    <ListView Grid.Row="1"
                              x:Name="CompareToolNav"
                              AutomationProperties.AutomationId="CompareToolNav"
                              SelectionMode="Single"
                              SelectionChanged="OnCompareToolSelectionChanged"
                              Loaded="OnCompareToolNavLoaded"
                              Background="Transparent"
                              Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasResult), Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="Margin" Value="4,2" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListViewItem Tag="diff"
                                      AutomationProperties.AutomationId="CompareNavDiff">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE8CB;" FontSize="16"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Diff"
                                           VerticalAlignment="Center" />
                                <InfoBadge Grid.Column="2"
                                           Value="{x:Bind ViewModel.FileChangeCount, Mode=OneWay}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </ListViewItem>
                        <ListViewItem Tag="planner"
                                      AutomationProperties.AutomationId="CompareNavPlanner">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE9D9;" FontSize="16"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Bandwidth Planner"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                        <ListViewItem Tag="duplicates"
                                      AutomationProperties.AutomationId="CompareNavDuplicates">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE8C8;" FontSize="16"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="Duplicates"
                                           VerticalAlignment="Center" />
                                <InfoBadge Grid.Column="2"
                                           Value="{x:Bind ViewModel.DuplicateGroupCount, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasDuplicates), Mode=OneWay}" />
                            </Grid>
                        </ListViewItem>
                    </ListView>

                    <!-- Footer: Export action buttons (visible after a comparison runs) -->
                    <StackPanel Grid.Row="2" Spacing="4" Padding="12,8,12,12"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0"
                                Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasResult), Mode=OneWay}">
                        <Button AutomationProperties.AutomationId="BtnExportMarkdown"
                                Command="{x:Bind ViewModel.ExportMarkdownCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE8A5;" FontSize="16" />
                                <TextBlock Text="Export to Markdown" />
                            </StackPanel>
                        </Button>
                        <Button AutomationProperties.AutomationId="BtnExportJson"
                                Command="{x:Bind ViewModel.ExportJsonCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Style="{StaticResource SubtleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE74E;" FontSize="16" />
                                <TextBlock Text="Export to JSON" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="1100" HorizontalAlignment="Stretch">

                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Pick the currently installed package version and a newer version. MSIXplainer reads the AppxBlockMap of each and reports exactly which blocks must travel over the wire — the same block-reuse mechanism the platform uses for updates." />

                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Old version (currently installed)"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="New version (target)"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <Grid Grid.Row="1" Grid.Column="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 AutomationProperties.AutomationId="OldPathBox"
                                 PlaceholderText="Path to old .msix / .msixbundle"
                                 Text="{x:Bind ViewModel.OldPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                AutomationProperties.AutomationId="BtnPickOld"
                                Command="{x:Bind ViewModel.PickOldCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                <TextBlock Text="Browse" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Swap button: flip Old↔New paths in one click when users picked them in the wrong order -->
                    <Button Grid.Row="1" Grid.Column="1"
                            AutomationProperties.AutomationId="BtnSwapPaths"
                            Command="{x:Bind ViewModel.SwapPathsCommand}"
                            ToolTipService.ToolTip="Swap old and new"
                            VerticalAlignment="Stretch"
                            Padding="10,0">
                        <FontIcon Glyph="&#xE8AB;" FontSize="14" />
                    </Button>

                    <Grid Grid.Row="1" Grid.Column="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 AutomationProperties.AutomationId="NewPathBox"
                                 PlaceholderText="Path to new .msix / .msixbundle"
                                 Text="{x:Bind ViewModel.NewPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                AutomationProperties.AutomationId="BtnPickNew"
                                Command="{x:Bind ViewModel.PickNewCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                                <TextBlock Text="Browse" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <Button AutomationProperties.AutomationId="BtnCompare"
                        Command="{x:Bind ViewModel.CompareCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8AB;" FontSize="16" />
                        <TextBlock Text="Compare" />
                    </StackPanel>
                </Button>

                <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                         Severity="Error"
                         Title="Comparison failed"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsClosable="False" />

                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                              Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsBusy), Mode=OneWay}"
                              HorizontalAlignment="Left" />

                <StackPanel Spacing="20"
                            Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasResult), Mode=OneWay}">

                    <!-- Warnings are shared across all three sub-views -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Warnings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <InfoBar IsOpen="True" Severity="Warning" Title="Warning"
                                         Message="{x:Bind}" IsClosable="False"
                                         Margin="0,0,0,8" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ═══ DIFF VIEW: headline cards + file inventory + per-package + top changes ═══ -->
                    <StackPanel Spacing="20"
                                Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsDiffView), Mode=OneWay}">

                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <Grid ColumnSpacing="24" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Full download (fresh install)"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Total wire bytes per device"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Bandwidth saved"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{x:Bind ViewModel.FullDownloadDisplay, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           AutomationProperties.AutomationId="TotalWireDisplay"
                                           Text="{x:Bind ViewModel.TotalWireDisplay, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           AutomationProperties.AutomationId="SavingsDisplay"
                                           Text="{x:Bind ViewModel.SavingsDisplay, Mode=OneWay}"
                                           Style="{StaticResource SubtitleTextBlockStyle}"
                                           Foreground="{ThemeResource SystemFillColorSuccessBrush}" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{x:Bind ViewModel.OldLabel, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{x:Bind ViewModel.NewLabel, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <Grid ColumnSpacing="24" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Block delta (matches SDK comparepackage.exe):"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           AutomationProperties.AutomationId="DeltaDownloadDisplay"
                                           Text="{x:Bind ViewModel.DeltaDownloadDisplay, Mode=OneWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="+ Metadata overhead (blockmap, signature, content-types):"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{x:Bind ViewModel.OverheadDisplay, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- File inventory & disk footprint -->
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="File inventory &amp; disk footprint"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Grid ColumnSpacing="20" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Added:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           AutomationProperties.AutomationId="AddedFilesDisplay"
                                           Text="{x:Bind ViewModel.AddedFilesDisplay, Mode=OneWay}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Deleted:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="0" Grid.Column="3"
                                           AutomationProperties.AutomationId="DeletedFilesDisplay"
                                           Text="{x:Bind ViewModel.DeletedFilesDisplay, Mode=OneWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Modified:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           AutomationProperties.AutomationId="ModifiedNetDisplay"
                                           Text="{x:Bind ViewModel.ModifiedNetDisplay, Mode=OneWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Unchanged:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="3"
                                           AutomationProperties.AutomationId="UnchangedDisplay"
                                           Text="{x:Bind ViewModel.UnchangedDisplay, Mode=OneWay}" />

                                <Border Grid.Row="2" Grid.ColumnSpan="4" Height="1" Margin="0,4"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="New package installed size:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           AutomationProperties.AutomationId="NewPackageTotalDisplay"
                                           Text="{x:Bind ViewModel.NewPackageTotalDisplay, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Additional disk needed:"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Row="3" Grid.Column="3"
                                           AutomationProperties.AutomationId="DiskSpaceNeededDisplay"
                                           Text="{x:Bind ViewModel.DiskSpaceNeededDisplay, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                    <!-- ═══ END DIFF VIEW PART 1 (per-package + top contributors come back below in DIFF VIEW PART 2) ═══ -->

                    <!-- ═══ BANDWIDTH PLANNER VIEW: fleet inputs + per-link projections ═══ -->
                    <StackPanel Spacing="20"
                                Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsBandwidthView), Mode=OneWay}">

                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Text="Multiply per-device download by your fleet size and project against typical link speeds." />

                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Device count" />
                        <NumberBox Grid.Row="1" Grid.Column="0"
                                   AutomationProperties.AutomationId="DeviceCountBox"
                                   Value="{x:Bind ViewModel.DeviceCount, Mode=TwoWay}"
                                   Minimum="1"
                                   SpinButtonPlacementMode="Inline" />

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Link speeds (Mbps, comma-separated)" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 AutomationProperties.AutomationId="LinkSpeedsBox"
                                 Text="{x:Bind ViewModel.LinkSpeedsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Cost per GB (USD, 0 = ignore)" />
                        <NumberBox Grid.Row="1" Grid.Column="2"
                                   AutomationProperties.AutomationId="CostPerGbBox"
                                   Value="{x:Bind ViewModel.CostPerGb, Mode=TwoWay}"
                                   Minimum="0"
                                   SmallChange="0.01"
                                   LargeChange="0.10" />
                    </Grid>

                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasBandwidth), Mode=OneWay}">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Total fleet transfer"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.TotalTransferDisplay, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="Estimated egress cost"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.EstimatedCostDisplay, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </StackPanel>
                            </Grid>

                            <ListView ItemsSource="{x:Bind ViewModel.LinkProjections}"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="12,6" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="16" Padding="12,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Link"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Grid.Column="1" Text="Per device"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Grid.Column="2" Text="Serial fleet (worst case)"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.HeaderTemplate>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LinkSpeedRow">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Link}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind PerDevice}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind SerialFleet}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                    <!-- ═══ END BANDWIDTH PLANNER VIEW ═══ -->

                    <!-- ═══ DIFF VIEW (part 2): per-package breakdown + top contributors ═══ -->
                    <StackPanel Spacing="20"
                                Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsDiffView), Mode=OneWay}">

                    <TextBlock Text="Per-package breakdown"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.PackageDiffs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PackageDiff">
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Label}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Old version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind OldVersion}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="New version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind NewVersion}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Architecture" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind Architecture}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Reuse" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind local:ComparePage.PercentToString(SavingsPercent)}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Added files" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind AddedFileCount}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Modified" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind ModifiedFileCount}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Removed" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind RemovedFileCount}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Unchanged" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind UnchangedFileCount}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Top contributors to the update download"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Up to 50 files sorted by on-wire delta. These are the files driving the update size." />
                    <ListView ItemsSource="{x:Bind ViewModel.TopFileChanges}"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,6" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="16" Padding="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="File"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="Status"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="2" Text="Delta on wire"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="3" Text="New size"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Grid.Column="4" Text="Blocks reused"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileDiffRow">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Status}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Delta}" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind NewSize}" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind BlocksReused}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    </StackPanel>
                    <!-- ═══ END DIFF VIEW (part 2) ═══ -->

                    <!-- ═══ DUPLICATES VIEW: optimization opportunities for duplicate files ═══ -->
                    <StackPanel Spacing="12"
                                Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsDuplicatesView), Mode=OneWay}">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                                   Text="Optimization opportunity: duplicate files" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Files with identical content that appear in multiple locations within the new package. Deduplicating these can shrink install footprint and update size." />

                        <!-- Empty-state when no duplicates were found in the new package -->
                        <InfoBar IsOpen="True"
                                 Severity="Success"
                                 Title="No duplicate files found"
                                 Message="Every file in the new package is unique. Nothing to deduplicate."
                                 IsClosable="False"
                                 Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.IsDuplicatesEmpty), Mode=OneWay}" />

                        <!-- Results when duplicates are present -->
                        <StackPanel Spacing="12"
                                    Visibility="{x:Bind local:ComparePage.BoolToVisibility(ViewModel.HasDuplicates), Mode=OneWay}">
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       AutomationProperties.AutomationId="DuplicatesHeadline"
                                       Text="{x:Bind ViewModel.DuplicatesHeadline, Mode=OneWay}" />
                            <ListView ItemsSource="{x:Bind ViewModel.DuplicateGroups}"
                                      SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="12,6" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="16" Padding="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Example path"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Copies"
                                                   HorizontalAlignment="Right"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Per copy"
                                                   HorizontalAlignment="Right"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Reclaimable"
                                                   HorizontalAlignment="Right"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DuplicateGroupRow">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind ExamplePath}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Copies}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind PerCopy}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Reclaim}" HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>
                    <!-- ═══ END DUPLICATES VIEW ═══ -->

                </StackPanel>
            </StackPanel>
            </ScrollViewer>
    </Grid>
</Page>